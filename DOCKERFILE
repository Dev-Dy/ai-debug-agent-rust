FROM rust:1.85-bookworm AS builder

WORKDIR /app
COPY . .

RUN cargo build --release

FROM debian:bookworm-slim

WORKDIR /app
RUN useradd --create-home --uid 10001 --shell /usr/sbin/nologin appuser
COPY --from=builder /app/target/release/ai_debug_agent /app/ai_debug_agent
RUN chown appuser:appuser /app/ai_debug_agent

EXPOSE 3000

USER appuser

ENTRYPOINT ["/app/ai_debug_agent"]
CMD ["api"]
