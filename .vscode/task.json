{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "cargo build",
      "group": "build"
    },
    {
      "label": "run-api",
      "type": "shell",
      "command": "cargo run -- api",
      "group": "build"
    },
    {
      "label": "run-worker",
      "type": "shell",
      "command": "cargo run -- worker",
      "group": "build"
    },
    {
      "label": "clippy",
      "type": "shell",
      "command": "cargo clippy --all-targets --all-features -D warnings"
    },
    {
      "label": "test",
      "type": "shell",
      "command": "cargo test"
    },
    {
      "label": "audit",
      "type": "shell",
      "command": "cargo audit"
    }
  ]
}